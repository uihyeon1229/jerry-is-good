# ====================================================================
# Track C 파이프라인 환경변수 예시
# 사용법: cp .env.example .env && 각 값 채우기
# ====================================================================

# ----- 법제처 Open API (Korean Law MCP) -----
# https://open.law.go.kr/LSO/openApi/guideList.do 에서 무료 발급
LAW_OC=your_law_oc_here

# ----- vLLM Nemotron 서버 -----
# Brev 인스턴스 내부에서 실행 시 localhost, 외부에서 붙일 경우 포트포워딩 엔드포인트
VLLM_BASE_URL=http://localhost:5000/v1
VLLM_MODEL=nemotron

# ----- HuggingFace (모델 다운로드/허브 업로드) -----
HF_TOKEN=hf_your_token_here
HF_HOME=/home/shadeform/.cache/huggingface

# ----- 생성 파이프라인 -----
PIPELINE_NUM_RECORDS=1000
PIPELINE_MAX_TOKENS_COT=16384
PIPELINE_MAX_TOKENS_QUESTION=1024
PIPELINE_MAX_TOKENS_METADATA=512
PIPELINE_MAX_TOKENS_JUDGE=1024
PIPELINE_MAX_PARALLEL=4

# ----- 경로 (인스턴스 기본값) -----
PIPELINE_CACHE_DIR=./cache
PIPELINE_OUTPUT_DIR=./output
PIPELINE_SEED_DIR=./cache/seeds
